{
  "plugin": "org.smartide.plugin.editor",
  "run": "echo 'change command from .si.json file'",
  "intelligence": {
    ".kts": {
      "enabled": true,
      "run": "kotlin-language-server"
    },
    ".py": {
      "enabled": true,
      "run": "pylsp"
    },
    ".json": {
      "enabled": true,
      "run": "vscode-json-language-server --stdio"
    },
    ".kt": {
      "enabled": false,
      "run": "kotlin-language-server"
    },
    ".xml": {
      "enabled": true,
      "run": "lemminx"
    },
    ".yml": {
      "enabled": true,
      "run": "yaml-language-server --stdio"
    }
  }
}